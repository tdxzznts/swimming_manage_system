<script setup lang="ts">
import { ref, computed, onMounted, onUnmounted } from 'vue'
import { useRouter } from 'vue-router'
import { ElMessage } from 'element-plus'
import {
  ArrowLeft,
  Medal,
  Wallet,
  Star,
  Document,
  Notebook,
  Clock,
  Trophy,
  Calendar,
  Tickets,
  Discount,
  Timer,
  Headset,
  Coin,
  CreditCard,
  QrCode
} from '@element-plus/icons-vue'
import { useUserStore } from '@/stores/user'
import { getRechargeAmounts, createRechargeOrder, getRechargeOrderStatus } from '@/api/recharge'
import type { RechargeAmount } from '@/api/recharge'

const router = useRouter()
const userStore = useUserStore()

// 会员信息
const memberInfo = ref({
  level: 2, // 1: 普通, 2: 银卡, 3: 金卡, 4: 钻石
  levelName: '银卡会员',
  levelEn: 'SILVER',
  cardNo: '8888 8888 8888',
  userName: '游泳爱好者',
  balance: 5000,
  points: 1200,
  validThru: '2026-12-31'
})

// 会员等级列表
const memberLevels = [
  {
    id: 1,
    type: 'normal',
    name: '普通会员',
    desc: '基础会员权益',
    price: 0
  },
  {
    id: 2,
    type: 'silver',
    name: '银卡会员',
    desc: '享受95折优惠',
    price: 199
  },
  {
    id: 3,
    type: 'gold',
    name: '金卡会员',
    desc: '享受9折优惠',
    price: 499
  },
  {
    id: 4,
    type: 'diamond',
    name: '钻石会员',
    desc: '享受85折优惠',
    price: 999
  }
]

// 会员权益
const memberBenefits = [
  {
    id: 1,
    icon: 'Discount',
    name: '预约折扣',
    desc: '会员享受专属折扣',
    value: '95折',
    tagType: 'success'
  },
  {
    id: 2,
    icon: 'Calendar',
    name: '优先预约',
    desc: '提前预约时段',
    value: '3天',
    tagType: 'warning'
  },
  {
    id: 3,
    icon: 'Tickets',
    name: '免费次数',
    desc: '每月免费游泳次数',
    value: '2次',
    tagType: 'danger'
  },
  {
    id: 4,
    icon: 'Timer',
    name: '延长时长',
    desc: '单次可延长时长',
    value: '+30分钟',
    tagType: 'info'
  },
  {
    id: 5,
    icon: 'Headset',
    name: '专属客服',
    desc: '7×24小时在线',
    value: 'VIP',
    tagType: 'success'
  },
  {
    id: 6,
    icon: 'Coin',
    name: '积分翻倍',
    desc: '消费积分倍数',
    value: '2倍',
    tagType: 'warning'
  }
]

// 最近使用记录
const recentRecords = ref([
  {
    id: 1,
    icon: 'Tickets',
    title: '游泳消费',
    time: '今天 14:30',
    amountText: '-¥50.00',
    amountClass: 'amount-decrease'
  },
  {
    id: 2,
    icon: 'Wallet',
    title: '账户充值',
    time: '昨天 10:20',
    amountText: '+¥100.00',
    amountClass: 'amount-increase'
  },
  {
    id: 3,
    icon: 'Star',
    title: '积分兑换',
    time: '3天前',
    amountText: '-200积分',
    amountClass: 'amount-decrease'
  }
])

// 充值金额选项 - 从字典获取
const rechargeAmounts = ref<Array<{ value: number; bonus: number; label: string }>>([])
const loadingAmounts = ref(false)

// 支付方式 - 支付宝为主，微信禁用
const paymentMethods = [
  { id: 'alipay', name: '支付宝', icon: 'CreditCard', disabled: false },
  { id: 'wechat', name: '微信支付', icon: 'Wallet', disabled: true }
]

const showLevelDetail = ref(false)
const showRecharge = ref(false)
const showPayQrCode = ref(false) // 显示支付二维码弹窗
const selectedAmount = ref(0)
const customAmount = ref('')
const selectedMethod = ref('alipay') // 默认选择支付宝

// 支付相关数据
const qrCodeUrl = ref('') // 二维码URL
const currentOrderNo = ref('') // 当前订单号
const pollingTimer = ref<number | null>(null) // 轮询定时器

function goBack() {
  router.back()
}

function handleRecharge() {
  showRecharge.value = true
}

function handleUpgrade() {
  showLevelDetail.value = true
}

function handleRecords() {
  router.push('/records')
}

function handleRules() {
  ElMessage.info('会员规则功能开发中...')
}

function handleSelectLevel(level: any) {
  console.log('Selected level:', level)
}

function handleUpgradeLevel(level: any) {
  ElMessage.success(`即将跳转到${level.name}购买页面...`)
}

function handleConfirmRecharge() {
  const amount = selectedAmount.value || Number(customAmount.value)
  if (!amount || amount <= 0) {
    ElMessage.warning('请选择充值金额')
    return
  }

  ElMessage.success(`充值¥${amount}功能开发中...`)
  showRecharge.value = false
}

function bubbleStyle(index: number) {
  const size = Math.random() * 25 + 8
  const left = Math.random() * 100
  const delay = Math.random() * 8
  const duration = Math.random() * 12 + 8
  return {
    width: `${size}px`,
    height: `${size}px`,
    left: `${left}%`,
    animationDelay: `${delay}s`,
    animationDuration: `${duration}s`
  }
}
</script>

