<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.dromara.swimming.mapper.SpOrderMapper">

    <resultMap id="SpOrderVoResult" type="org.dromara.swimming.domain.vo.SpOrderVo">
        <id property="id" column="id"/>
        <result property="orderNo" column="order_no"/>
        <result property="userId" column="user_id"/>
        <result property="userName" column="user_name"/>
        <result property="reservationId" column="reservation_id"/>
        <result property="orderType" column="order_type"/>
        <result property="amount" column="amount"/>
        <result property="discountAmount" column="discount_amount"/>
        <result property="actualAmount" column="actual_amount"/>
        <result property="getPoint" column="get_point"/>
        <result property="payType" column="pay_type"/>
        <result property="payStatus" column="pay_status"/>
        <result property="payTime" column="pay_time"/>
        <result property="tradeNo" column="trade_no"/>
        <result property="thirdPartyNo" column="third_party_no"/>
        <result property="refundAmount" column="refund_amount"/>
        <result property="refundTime" column="refund_time"/>
        <result property="refundReason" column="refund_reason"/>
        <result property="status" column="status"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <select id="selectVoList" resultMap="SpOrderVoResult">
        SELECT
            o.id,
            o.order_no,
            o.user_id,
            u.nick_name AS user_name,
            o.reservation_id,
            o.order_type,
            o.amount,
            o.discount_amount,
            o.actual_amount,
            o.get_point,
            o.pay_type,
            o.pay_status,
            o.pay_time,
            o.trade_no,
            o.third_party_no,
            o.refund_amount,
            o.refund_time,
            o.refund_reason,
            o.status,
            o.remark
        FROM sp_order o
        LEFT JOIN sys_user u ON o.user_id = u.user_id
        <where>
            <if test="ew.orderNo != null and ew.orderNo != ''">
                AND o.order_no = #{ew.orderNo}
            </if>
            <if test="ew.userName != null and ew.userName != ''">
                AND u.nick_name LIKE CONCAT('%', #{ew.userName}, '%')
            </if>
            <if test="ew.orderType != null and ew.orderType != ''">
                AND o.order_type = #{ew.orderType}
            </if>
            <if test="ew.payType != null and ew.payType != ''">
                AND o.pay_type = #{ew.payType}
            </if>
            <if test="ew.payStatus != null and ew.payStatus != ''">
                AND o.pay_status = #{ew.payStatus}
            </if>
            <if test="ew.status != null and ew.status != ''">
                AND o.status = #{ew.status}
            </if>
        </where>
        ORDER BY o.create_time DESC
    </select>

    <select id="selectVoPage" resultMap="SpOrderVoResult">
        SELECT
            o.id,
            o.order_no,
            o.user_id,
            u.nick_name AS user_name,
            o.reservation_id,
            o.order_type,
            o.amount,
            o.discount_amount,
            o.actual_amount,
            o.get_point,
            o.pay_type,
            o.pay_status,
            o.pay_time,
            o.trade_no,
            o.third_party_no,
            o.refund_amount,
            o.refund_time,
            o.refund_reason,
            o.status,
            o.remark
        FROM sp_order o
        LEFT JOIN sys_user u ON o.user_id = u.user_id
        <where>
            <if test="ew.orderNo != null and ew.orderNo != ''">
                AND o.order_no = #{ew.orderNo}
            </if>
            <if test="ew.userName != null and ew.userName != ''">
                AND u.nick_name LIKE CONCAT('%', #{ew.userName}, '%')
            </if>
            <if test="ew.orderType != null and ew.orderType != ''">
                AND o.order_type = #{ew.orderType}
            </if>
            <if test="ew.payType != null and ew.payType != ''">
                AND o.pay_type = #{ew.payType}
            </if>
            <if test="ew.payStatus != null and ew.payStatus != ''">
                AND o.pay_status = #{ew.payStatus}
            </if>
            <if test="ew.status != null and ew.status != ''">
                AND o.status = #{ew.status}
            </if>
        </where>
        ORDER BY o.create_time DESC
    </select>

    <select id="selectVoById" resultMap="SpOrderVoResult">
        SELECT
            o.id,
            o.order_no,
            o.user_id,
            u.nick_name AS user_name,
            o.reservation_id,
            o.order_type,
            o.amount,
            o.discount_amount,
            o.actual_amount,
            o.get_point,
            o.pay_type,
            o.pay_status,
            o.pay_time,
            o.trade_no,
            o.third_party_no,
            o.refund_amount,
            o.refund_time,
            o.refund_reason,
            o.status,
            o.remark
        FROM sp_order o
        LEFT JOIN sys_user u ON o.user_id = u.user_id
        WHERE o.id = #{id}
    </select>

</mapper>
