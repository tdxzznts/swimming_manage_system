<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.dromara.swimming.mapper.SpMemberCardMapper">

    <resultMap id="SpMemberCardVoResult" type="org.dromara.swimming.domain.vo.SpMemberCardVo">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="userName" column="user_name"/>
        <result property="cardNo" column="card_no"/>
        <result property="cardLevel" column="card_level"/>
        <result property="balance" column="balance"/>
        <result property="totalRecharge" column="total_recharge"/>
        <result property="totalConsume" column="total_consume"/>
        <result property="totalPoint" column="total_point"/>
        <result property="freeTimes" column="free_times"/>
        <result property="issueDate" column="issue_date"/>
        <result property="expiryDate" column="expiry_date"/>
        <result property="status" column="status"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <select id="selectVoList" resultMap="SpMemberCardVoResult">
        SELECT
            c.id,
            c.user_id,
            u.nick_name AS user_name,
            c.card_no,
            c.card_level,
            c.balance,
            c.total_recharge,
            c.total_consume,
            c.total_point,
            c.free_times,
            c.issue_date,
            c.expiry_date,
            c.status,
            c.remark
        FROM sp_member_card c
        LEFT JOIN sys_user u ON c.user_id = u.user_id
        <where>
            <if test="ew.userName != null and ew.userName != ''">
                AND u.nick_name LIKE CONCAT('%', #{ew.userName}, '%')
            </if>
            <if test="ew.cardNo != null and ew.cardNo != ''">
                AND c.card_no = #{ew.cardNo}
            </if>
            <if test="ew.cardLevel != null and ew.cardLevel != ''">
                AND c.card_level = #{ew.cardLevel}
            </if>
            <if test="ew.status != null and ew.status != ''">
                AND c.status = #{ew.status}
            </if>
        </where>
        ORDER BY c.create_time DESC
    </select>

    <select id="selectVoPage" resultMap="SpMemberCardVoResult">
        SELECT
            c.id,
            c.user_id,
            u.nick_name AS user_name,
            c.card_no,
            c.card_level,
            c.balance,
            c.total_recharge,
            c.total_consume,
            c.total_point,
            c.free_times,
            c.issue_date,
            c.expiry_date,
            c.status,
            c.remark
        FROM sp_member_card c
        LEFT JOIN sys_user u ON c.user_id = u.user_id
        <where>
            <if test="ew.userName != null and ew.userName != ''">
                AND u.nick_name LIKE CONCAT('%', #{ew.userName}, '%')
            </if>
            <if test="ew.cardNo != null and ew.cardNo != ''">
                AND c.card_no = #{ew.cardNo}
            </if>
            <if test="ew.cardLevel != null and ew.cardLevel != ''">
                AND c.card_level = #{ew.cardLevel}
            </if>
            <if test="ew.status != null and ew.status != ''">
                AND c.status = #{ew.status}
            </if>
        </where>
        ORDER BY c.create_time DESC
    </select>

    <select id="selectVoById" resultMap="SpMemberCardVoResult">
        SELECT
            c.id,
            c.user_id,
            u.nick_name AS user_name,
            c.card_no,
            c.card_level,
            c.balance,
            c.total_recharge,
            c.total_consume,
            c.total_point,
            c.free_times,
            c.issue_date,
            c.expiry_date,
            c.status,
            c.remark
        FROM sp_member_card c
        LEFT JOIN sys_user u ON c.user_id = u.user_id
        WHERE c.id = #{id}
    </select>

</mapper>
